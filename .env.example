JIRA_BASE_URL=https://jiradc.example.com

# Optional Jira settings
JIRA_REST_PREFIX=/rest/api/2
JIRA_TIMEOUT_SECONDS=15
JIRA_VERIFY_SSL=true
JIRA_MAX_RESULTS=25
JIRA_DEFAULT_SEARCH_FIELDS=summary,status,priority,issuetype,project,assignee,updated
JIRA_DEFAULT_ISSUE_FIELDS=summary,status,priority,issuetype,project,assignee,reporter,description,labels,updated,created

# Optional MCP server settings
MCP_NAME=jira-readonly
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
MCP_LOG_LEVEL=INFO
